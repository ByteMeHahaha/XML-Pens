<?xml version="1.0" encoding="UTF-8"?>
<xs:schema xmlns:xs="http://www.w3.org/2001/XMLSchema">
  <!-- Root Element definition -->
  <xs:element name="pens">
    <xs:complexType>
      <xs:sequence>
        <!-- Record element -->
        <xs:element name="pen" type="pen-type" minOccurs="1" maxOccurs="unbounded" />
      </xs:sequence>
    </xs:complexType>
  </xs:element>

  <!-- Pen record type -->
  <xs:complexType name="pen-type">
    <xs:sequence>
      <xs:element name="brand" type="xs:string" />
      <xs:element name="model" type="xs:string">
        <xs:annotation>
          <xs:documentation>The pen's specific model. For example, with the Parker Jotter, "Jotter"
            is the model.</xs:documentation>
        </xs:annotation>
      </xs:element>

      <!-- Pen recommended price -->
      <xs:element name="price" minOccurs="0">
        <!-- Documentation -->
        <xs:annotation>
          <xs:documentation>The price for the pen. This may either be the manufacturer's
            recommended price or the price found online. If the price was found online, the "src"
            attribute must be present.</xs:documentation>
        </xs:annotation>

        <!-- Type Definition -->
        <xs:complexType>
          <xs:simpleContent>
            <xs:extension base="xs:double">
              <!-- Currency for price -->
              <xs:attribute
                name="currency"
                type="currency-type"
                use="optional"
                default="ZAR">
                <xs:annotation>
                  <xs:documentation>The abbreviation for the currency used for the price.</xs:documentation>
                </xs:annotation>
              </xs:attribute>
            </xs:extension>
          </xs:simpleContent>
        </xs:complexType>
      </xs:element>
    </xs:sequence>

    <xs:attribute name="pen-id" type="xs:ID">
      <xs:annotation>
        <xs:documentation>
          The unique identifier for the pen. Cannot start with a number.
        </xs:documentation>
      </xs:annotation>
    </xs:attribute>
  </xs:complexType>

  <xs:simpleType name="currency-type">
    <xs:restriction base="xs:string">
      <!-- Currency Abbreviation, e.g., USD -->
      <xs:pattern value="[A-Z]{3}" />
    </xs:restriction>
  </xs:simpleType>
</xs:schema>
